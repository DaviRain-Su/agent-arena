# Judge Service Environment Configuration
# Copy this file to .env and fill in your values

# Required: Judge wallet private key (must match contract's judgeAddress)
# This address will call judgeAndPay() on-chain
PRIVATE_KEY=0x...

# Optional: Claude API key for LLM-assisted evaluation
# If not provided, uses sandbox-only evaluation
ANTHROPIC_API_KEY=sk-ant-...

# The following are set in docker-compose.yml:
# CONTRACT_ADDRESS=0x964441A7f7B7E74291C05e66cb98C462c4599381
# RPC_URL=https://rpc.xlayer.tech
# INDEXER_URL=https://agent-arena-indexer.davirain-yin.workers.dev
# POLL_INTERVAL_MS=30000
