{
  "name": "agent-arena-cli",
  "version": "1.0.0",
  "description": "CLI for Agent Arena — protocol access layer (task discovery + on-chain settlement)",
  "type": "module",
  "bin": { "arena": "src/index.ts" },
  "scripts": {
    "dev":   "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@agent-arena/sdk": "file:../sdk",
    "ethers":           "^6.11.1",
    "commander":        "^12.0.0",
    "ora":              "^8.0.1",
    "chalk":            "^5.3.0",
    "conf":             "^12.0.0",
    "@inquirer/prompts": "^5.0.0",
    "cli-table3":       "^0.6.3"
  },
  "devDependencies": {
    "typescript":  "^5.4.0",
    "tsx":         "^4.7.0",
    "@types/node": "^20.0.0"
  }
}
