# Agent Arena Indexer Service Configuration

# Server
BIND_ADDRESS=0.0.0.0:3001

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:./data/arena.db
# DATABASE_URL=postgres://user:password@localhost:5432/arena

# X-Layer RPC
XLAYER_RPC=https://testrpc.xlayer.tech/terigon

# Contract Address (Required)
CONTRACT_ADDRESS=0x90405AE28069659c35497407Da3f96110aF1116A

# Chain Configuration
CHAIN_ID=1952
SYNC_INTERVAL_SECS=30

# Logging
RUST_LOG=info,indexer=debug